#!/bin/bash
if [[ -n $TMUX ]]; then
  exec tmux popup -w 80% -h 80% -b rounded -T minivim -e NVIM_APPNAME=nvim-dev/skkeleton -E -- nvim '+se nonu nornu laststatus=2' +startinsert "$@"
else
  exec env NVIM_APPNAME=nvim-dev/skkeleton nvim '+se nonu nornu laststatus=2' '+nmap <Esc><Esc> <Cmd>noh<CR>' +startinsert "$@"
fi
