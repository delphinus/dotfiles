#!/bin/bash
# claude-obsidian-backfill-links
#
# 既存の Obsidian ノートに、同じ session_id を持つノート間の related リンクをバックフィルする。
# - frontmatter の related フィールドにリンクを追加
# - 本文に > [!link] Previous Sessions セクションを追加
# 既にリンク済みのものはスキップし、不足分のみ追記する。
#
# Usage:
#   claude-obsidian-backfill-links            # 実行
#   claude-obsidian-backfill-links --dry-run   # 変更内容のプレビューのみ

set -euo pipefail

VAULT_DIR="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes/Claude Code"
DRY_RUN=false

[[ "${1:-}" == "--dry-run" ]] && DRY_RUN=true

[[ ! -d "$VAULT_DIR" ]] && { echo "Error: Vault not found: $VAULT_DIR" >&2; exit 1; }

# session_id とファイルパスの対応表を作成
mapping=$(mktemp)
trap 'rm -f "$mapping"' EXIT

while IFS= read -r file; do
  sid=$(sed -n 's/^session_id: //p' "$file" | head -1)
  [[ -n "$sid" ]] && printf '%s\t%s\n' "$sid" "$file"
done < <(find "$VAULT_DIR" -name '*.md' -type f) > "$mapping"

# 複数ファイルを持つ session_id を抽出
dup_sids=$(cut -f1 "$mapping" | sort | uniq -d)

updated=0
skipped=0

while IFS= read -r sid; do
  [[ -z "$sid" ]] && continue

  # この session_id に属するファイルを収集
  files=()
  while IFS=$'\t' read -r _ f; do
    files+=("$f")
  done < <(grep "^${sid}	" "$mapping")

  sid_short="${sid:0:8}"
  echo "Session ${sid_short}...: ${#files[@]} notes"

  for file in "${files[@]}"; do
    bn=$(basename "$file")

    # 他のノートのベース名を収集
    others=()
    for other in "${files[@]}"; do
      [[ "$other" == "$file" ]] && continue
      others+=("$(basename "$other" .md)")
    done

    # まだリンクされていないものを特定
    missing=()
    for name in "${others[@]}"; do
      grep -q "\\[\\[${name}\\]\\]" "$file" || missing+=("$name")
    done

    if [[ ${#missing[@]} -eq 0 ]]; then
      ((skipped++))
      continue
    fi

    echo "  [update] $bn (+${#missing[@]} link(s))"
    for name in "${missing[@]}"; do
      echo "    + [[${name}]]"
    done

    $DRY_RUN && { ((updated++)); continue; }

    # --- frontmatter の related フィールド ---
    end_fm=$(grep -n '^---$' "$file" | sed -n '2p' | cut -d: -f1)
    if [[ -z "$end_fm" ]]; then
      echo "    [warn] frontmatter not found, skipping"
      continue
    fi

    temp=$(mktemp)
    if grep -q '^related:' "$file"; then
      # 既存の related セクション末尾に追記
      NEW_ENTRIES=$(printf '  - "[[%s]]"\n' "${missing[@]}") \
        awk '
          /^related:/ { in_rel=1 }
          in_rel && !/^related:/ && !/^  - / {
            printf "%s\n", ENVIRON["NEW_ENTRIES"]
            in_rel=0
          }
          { print }
          END { if (in_rel) printf "%s\n", ENVIRON["NEW_ENTRIES"] }
        ' "$file" > "$temp"
      mv "$temp" "$file"
    else
      # related フィールドを新規追加（frontmatter の閉じ --- の直前）
      head -n "$((end_fm - 1))" "$file" > "$temp"
      printf 'related:\n' >> "$temp"
      for name in "${missing[@]}"; do
        printf '  - "[[%s]]"\n' "$name" >> "$temp"
      done
      tail -n +"$end_fm" "$file" >> "$temp"
      mv "$temp" "$file"
    fi

    # --- 本文のリンクセクション ---
    temp=$(mktemp)
    if grep -q '> \[!link\]' "$file"; then
      # 既存セクションの末尾（空行の直前）に追記
      NEW_LINKS=$(printf '> - [[%s]]\n' "${missing[@]}") \
        awk '
          /^> \[!link\]/ { in_link=1 }
          in_link && /^$/ {
            printf "%s\n", ENVIRON["NEW_LINKS"]
            in_link=0
          }
          { print }
          END { if (in_link) printf "%s\n", ENVIRON["NEW_LINKS"] }
        ' "$file" > "$temp"
      mv "$temp" "$file"
    else
      # リンクセクションを新規挿入（frontmatter 直後）
      end_fm=$(grep -n '^---$' "$file" | sed -n '2p' | cut -d: -f1)
      head -n "$end_fm" "$file" > "$temp"
      printf '\n> [!link] Previous Sessions\n' >> "$temp"
      for name in "${missing[@]}"; do
        printf '> - [[%s]]\n' "$name" >> "$temp"
      done
      printf '\n' >> "$temp"
      tail -n +"$((end_fm + 1))" "$file" >> "$temp"
      mv "$temp" "$file"
    fi

    ((updated++))
  done
done <<< "$dup_sids"

echo ""
if $DRY_RUN; then
  echo "[dry-run] $updated notes would be updated, $skipped already linked"
else
  echo "Complete: $updated updated, $skipped already linked"
fi
