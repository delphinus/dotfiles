#!/bin/bash

# claude-obsidian-save - Save Claude Code conversations to Obsidian vault
#
# Claude Code のフックから呼び出され、会話やツール使用を Obsidian ノートに記録する。
# 各セッションにつき1つの .md ファイルを作成し、イベントを時系列で追記する。
#
# 対応フックイベント:
#   UserPromptSubmit  - ユーザーの入力を記録
#   Stop              - アシスタントの応答を記録
#   PostToolUse       - ツール使用を記録（Bash/ExitPlanMode/Edit/Write）
#   SessionEnd        - 要約を生成してフロントマターの後に挿入
#
# 設定: ~/.claude/settings.json の hooks セクション

# 要約生成の claude -p 呼び出しによる再帰を防止
[[ -n "$CLAUDE_OBSIDIAN_SAVING" ]] && exit 0

VAULT_DIR="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/Notes/Claude Code"
CACHE_DIR="$HOME/.cache/claude-obsidian"
NOTIFY="$HOME/git/dotfiles/bin/claude-notify"

INPUT=$(cat)

SESSION_ID=$(jq -r '.session_id // empty' <<< "$INPUT")
HOOK_EVENT=$(jq -r '.hook_event_name // empty' <<< "$INPUT")
CWD=$(jq -r '.cwd // empty' <<< "$INPUT")

[[ -z "$SESSION_ID" ]] && exit 0

if [[ ! -d "$VAULT_DIR" ]]; then
  mkdir -p "$VAULT_DIR" 2>/dev/null || {
    "$NOTIFY" 'Claude Obsidian Save' "Vault ディレクトリが見つかりません: $VAULT_DIR" 2>/dev/null
    exit 0
  }
fi

mkdir -p "$CACHE_DIR"

SESSION_CACHE="$CACHE_DIR/$SESSION_ID"
SID_SHORT=${SESSION_ID:0:4}

# プロンプトから人間が読めるタイトルを生成する（alias 用）
make_display_title() {
  local raw
  raw=$(head -1 <<< "$1" | cut -c1-50)
  # ファイル名に使えない文字のみ除去（スペースは保持）
  printf '%s' "$raw" | sed -E 's/[\/\\:*?"<>|]//g; s/^[[:space:]]+//; s/[[:space:]]+$//'
}

# ファイル名用に kebab-case に変換する
make_filename_title() {
  local raw
  raw=$(head -1 <<< "$1" | cut -c1-50)
  # ファイル名に使えない文字を除去し、空白をハイフンに変換
  printf '%s' "$raw" | sed -E 's/[\/\\:*?"<>|]//g; s/[[:space:]]+/-/g; s/-+/-/g; s/^-//; s/-$//'
}

# id 用に ASCII 部分のみ抽出する
make_id_slug() {
  local slug
  slug=$(printf '%s' "$1" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9-]//g; s/-+/-/g; s/^-//; s/-$//')
  if [[ -z "$slug" ]]; then
    LC_ALL=C tr -dc 'A-Z' < /dev/urandom | head -c 4
  else
    printf '%s' "$slug"
  fi
}

get_or_create_note() {
  local prompt="$1"

  if [[ -f "$SESSION_CACHE" ]]; then
    cat "$SESSION_CACHE"
    return
  fi

  local project
  project=$(basename "${CWD:-unknown}")
  local ts
  ts=$(date +"%Y%m%d-%H%M%S")

  local display_title
  display_title=$(make_display_title "$prompt")
  [[ -z "$display_title" ]] && display_title="$project"

  local file_title
  file_title=$(make_filename_title "$prompt")
  [[ -z "$file_title" ]] && file_title="$project"

  local id_slug
  id_slug=$(make_id_slug "$file_title")

  local note_id="${ts}-${SID_SHORT}-${id_slug}"
  local project_dir="$VAULT_DIR/$project"
  mkdir -p "$project_dir"
  local note="$project_dir/${ts}-${SID_SHORT}-${file_title}.md"

  printf '%s' "$note" > "$SESSION_CACHE"

  {
    printf -- '---\n'
    printf 'id: %s\n' "$note_id"
    printf 'aliases:\n'
    printf '  - %s\n' "$display_title"
    printf 'tags:\n'
    printf '  - claude-code\n'
    printf 'date: %s\n' "$(date +"%Y-%m-%dT%H:%M:%S")"
    printf 'session_id: %s\n' "$SESSION_ID"
    printf 'hostname: %s\n' "$(hostname)"
    printf 'cwd: %s\n' "$CWD"
    printf -- '---\n\n'
  } > "$note"

  printf '%s' "$note"
}

# Bash コマンドのフィルタリング用ブロックリスト
SKIP_COMMANDS="ls|cat|head|tail|wc|file|stat|which|where|type|echo|printf|pwd|cd|test|true|false|grep|rg|find|diff|sort|uniq|tr|cut|mkdir|rmdir|rm|cp|mv|ln|chmod|chown|touch|basename|dirname|realpath|readlink|tree|du|df|less|more|xargs|tee|whoami|hostname|date|uname|env|set|export|alias|id|jq"

# コマンド文字列に記録対象のコマンドが含まれるか判定
should_record_command() {
  local cmd="$1"
  local skip_pattern="^(${SKIP_COMMANDS})([[:space:]]|$)"
  # パイプやチェインで分割して各コマンドをチェック
  while IFS= read -r segment; do
    # 先頭の空白を除去
    segment="${segment#"${segment%%[![:space:]]*}"}"
    [[ -z "$segment" ]] && continue
    if ! [[ "$segment" =~ $skip_pattern ]]; then
      return 0
    fi
  done <<< "$(printf '%s' "$cmd" | sed -E 's/[|;&]+/\n/g')"
  return 1
}

case "$HOOK_EVENT" in
  PostToolUse)
    TOOL_NAME=$(jq -r '.tool_name // empty' <<< "$INPUT")

    case "$TOOL_NAME" in
      Bash)
        COMMAND=$(jq -r '.tool_input.command // empty' <<< "$INPUT")
        [[ -z "$COMMAND" ]] && exit 0

        should_record_command "$COMMAND" || exit 0

        NOTE=$(get_or_create_note "")
        [[ -f "$NOTE" ]] || exit 0

        DESCRIPTION=$(jq -r '.tool_input.description // empty' <<< "$INPUT")
        TS=$(date +"%H:%M:%S")

        if [[ -n "$DESCRIPTION" ]]; then
          TITLE="$DESCRIPTION ($TS)"
        else
          TITLE="Command ($TS)"
        fi

        {
          printf '> [!terminal]- %s\n' "$TITLE"
          printf '> ```bash\n'
          while IFS= read -r line; do
            printf '> %s\n' "$line"
          done <<< "$COMMAND"
          printf '> ```\n\n'
        } >> "$NOTE"
        ;;

      ExitPlanMode)
        PLAN=$(jq -r '.tool_input.plan // empty' <<< "$INPUT")
        [[ -z "$PLAN" ]] && exit 0

        NOTE=$(get_or_create_note "")
        [[ -f "$NOTE" ]] || exit 0

        TS=$(date +"%H:%M:%S")
        # プランの最初の行（見出し）をタイトルに使用
        PLAN_TITLE=$(head -1 <<< "$PLAN" | sed 's/^#* *//')
        [[ -z "$PLAN_TITLE" ]] && PLAN_TITLE="Plan"

        {
          printf '> [!plan]- %s (%s)\n' "$PLAN_TITLE" "$TS"
          while IFS= read -r line; do
            printf '> %s\n' "$line"
          done <<< "$PLAN"
          printf '\n'
        } >> "$NOTE"
        ;;

      Edit|Write)
        FILE_PATH=$(jq -r '.tool_input.file_path // empty' <<< "$INPUT")
        [[ -z "$FILE_PATH" ]] && exit 0

        NOTE=$(get_or_create_note "")
        [[ -f "$NOTE" ]] || exit 0

        TS=$(date +"%H:%M:%S")
        # CWD からの相対パスに変換（CWD 配下の場合）
        if [[ -n "$CWD" && "$FILE_PATH" == "$CWD"/* ]]; then
          DISPLAY_PATH="${FILE_PATH#"$CWD"/}"
        else
          DISPLAY_PATH="$FILE_PATH"
        fi

        printf '> [!file] %s: %s (%s)\n\n' "$TOOL_NAME" "$DISPLAY_PATH" "$TS" >> "$NOTE"
        ;;
    esac
    ;;

  UserPromptSubmit)
    PROMPT=$(jq -r '.prompt // empty' <<< "$INPUT")
    # 内部通知（バックグラウンドタスクの結果等）はスキップ
    [[ "$PROMPT" == *"<task-notification>"* ]] && exit 0
    NOTE=$(get_or_create_note "$PROMPT")
    TS=$(date +"%H:%M:%S")
    {
      printf '## User (%s)\n\n' "$TS"
      printf '%s\n\n' "$PROMPT"
    } >> "$NOTE"
    ;;

  Stop)
    MSG=$(jq -r '.last_assistant_message // empty' <<< "$INPUT")
    # まだノートが無い場合、アシスタントメッセージからタイトルを生成
    NOTE=$(get_or_create_note "$MSG")
    TS=$(date +"%H:%M:%S")
    [[ -n "$MSG" ]] && {
      printf '## Assistant (%s)\n\n' "$TS"
      printf '%s\n\n' "$MSG"
    } >> "$NOTE"
    ;;

  SessionEnd)
    [[ -f "$SESSION_CACHE" ]] || exit 0
    NOTE=$(cat "$SESSION_CACHE")
    [[ -f "$NOTE" ]] || { rm -f "$SESSION_CACHE"; exit 0; }

    NOTE_CONTENT=$(head -c 100000 "$NOTE")

    # 要約を生成（haiku で高速に処理）
    SUMMARY=$(CLAUDE_OBSIDIAN_SAVING=1 claude -p --model haiku \
      "以下の Claude Code の会話ログを日本語で3〜5行で要約してください。要約のみを出力し、前置きは不要です。" \
      <<< "$NOTE_CONTENT" 2>/dev/null) || true

    if [[ -n "$SUMMARY" ]]; then
      TEMP=$(mktemp)
      END_FM=$(grep -n '^---$' "$NOTE" | sed -n '2p' | cut -d: -f1)
      if [[ -n "$END_FM" ]]; then
        head -n "$END_FM" "$NOTE" > "$TEMP"
        {
          printf '\n> [!summary]\n'
          while IFS= read -r line; do
            printf '> %s\n' "$line"
          done <<< "$SUMMARY"
          printf '\n'
        } >> "$TEMP"
        tail -n +"$((END_FM + 1))" "$NOTE" >> "$TEMP"
        mv "$TEMP" "$NOTE"
      else
        rm -f "$TEMP"
      fi
    fi

    # タイトルがプロジェクト名のみ（フォールバック値）の場合、会話内容からタイトルを再生成
    BASENAME=$(basename "$NOTE" .md)
    # ファイル名のプレフィックス（YYYYMMDD-HHMMSS-SSID）を除いたタイトル部分
    PREFIX=$(printf '%s' "$BASENAME" | cut -d'-' -f1-3)
    CURRENT_TITLE=$(printf '%s' "$BASENAME" | cut -d'-' -f4-)
    PROJECT=$(basename "$(dirname "$NOTE")")

    if [[ "$CURRENT_TITLE" == "$PROJECT" ]]; then
      NEW_TITLE=$(CLAUDE_OBSIDIAN_SAVING=1 claude -p --model haiku \
        "以下の Claude Code の会話ログの内容を表す短いタイトル（50文字以内）を日本語で生成してください。タイトルのみを出力し、前置きや引用符は不要です。" \
        <<< "$NOTE_CONTENT" 2>/dev/null) || true

      if [[ -n "$NEW_TITLE" ]]; then
        FILE_TITLE=$(make_filename_title "$NEW_TITLE")
        DISPLAY_TITLE=$(make_display_title "$NEW_TITLE")
        ID_SLUG=$(make_id_slug "$FILE_TITLE")

        if [[ -n "$FILE_TITLE" ]]; then
          NEW_NOTE="$(dirname "$NOTE")/${PREFIX}-${FILE_TITLE}.md"
          NEW_ID="${PREFIX}-${ID_SLUG}"

          # フロントマターの id と aliases を更新
          sed -i '' "s/^id: .*/id: ${NEW_ID}/" "$NOTE"
          sed -i '' "/^aliases:/,/^[^ ]/{s/^  - .*/  - ${DISPLAY_TITLE}/;}" "$NOTE"

          mv "$NOTE" "$NEW_NOTE"
        fi
      fi
    fi

    rm -f "$SESSION_CACHE"
    ;;
esac

exit 0
